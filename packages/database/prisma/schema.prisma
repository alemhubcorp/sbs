generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    TenantStatus @default(active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations Organization[]
  orgUnits      OrgUnit[]
  memberships   Membership[]
  sellerProfiles SellerProfile[]
  buyerProfiles  BuyerProfile[]
  wholesaleRfqs  WholesaleRfq[]
  wholesaleDeals WholesaleDeal[]
  documents      Document[]
  operationalAssignments OperationalAssignment[]
}

model Organization {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  legalName  String?
  partnerType PartnerType?
  status     OrganizationStatus @default(active)
  onboardingStatus String @default("draft")
  contactName String?
  contactEmail String?
  contactPhone String?
  address    String?
  country    String?
  notes      String?
  socialLinks Json?
  linkedUserId String?
  submittedAt DateTime?
  reviewedAt DateTime?
  reviewedByUserId String?
  reviewNote String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  linkedUser  User?        @relation("OrganizationLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  orgUnits    OrgUnit[]
  memberships Membership[]
  operationalAssignments OperationalAssignment[]

  @@index([tenantId])
  @@index([partnerType])
  @@index([status])
  @@index([linkedUserId])
}

model OrgUnit {
  id             String   @id @default(cuid())
  tenantId       String
  organizationId String
  parentId       String?
  name           String
  code           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       OrgUnit?     @relation("OrgUnitHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     OrgUnit[]    @relation("OrgUnitHierarchy")
  memberships  Membership[]

  @@index([tenantId])
  @@index([organizationId])
  @@index([parentId])
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  firstName       String
  lastName        String
  status          UserStatus @default(invited)
  externalSubject String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userRoles    UserRole[]
  memberships  Membership[]
  sellerProfiles SellerProfile[]
  buyerProfiles  BuyerProfile[]
  linkedOrganizations Organization[] @relation("OrganizationLinkedUser")
  requestedRfqs WholesaleRfq[] @relation("RfqRequestedByUser")
  contractVersions ContractVersion[]
  documents        Document[]
  notifications    Notification[]
  consentRecords   ConsentRecord[]
  requestedApprovals Approval[]      @relation("ApprovalRequestedBy")
  decidedApprovals   Approval[]      @relation("ApprovalDecidedBy")
  operationalAssignments OperationalAssignment[]
}

model SellerProfile {
  id          String      @id @default(cuid())
  userId      String?
  tenantId    String?
  sellerType  SellerType
  supplierType SupplierType @default(trader)
  displayName String
  companyName String?
  companyAddress String?
  contactPerson String?
  contactEmail String?
  contactPhone String?
  socialLinks Json?
  country     String?
  status      ProfileStatus @default(active)
  onboardingStatus String @default("draft")
  submittedAt DateTime?
  reviewedAt DateTime?
  reviewedByUserId String?
  reviewNote String?
  payoutBeneficiaryName String?
  payoutCompanyName     String?
  payoutBankName        String?
  payoutAccountNumber   String?
  payoutIban            String?
  payoutSwiftBic        String?
  payoutStatus          String        @default("unverified")
  payoutReviewNote      String?
  payoutVerifiedAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  products Product[]
  retailOrders RetailOrder[]
  wholesaleQuotes WholesaleQuote[]
  wholesaleDeals  WholesaleDeal[]

  @@index([userId])
  @@index([tenantId])
}

model BuyerProfile {
  id          String      @id @default(cuid())
  userId      String?
  tenantId    String?
  buyerType   BuyerType
  displayName String
  personalAddress String?
  contactPerson String?
  contactEmail String?
  contactPhone String?
  companyName String?
  legalName String?
  companyAddress String?
  socialLinks Json?
  status      ProfileStatus @default(active)
  b2bStatus String @default("not_requested")
  b2bSubmittedAt DateTime?
  b2bReviewedAt DateTime?
  b2bReviewedByUserId String?
  b2bReviewNote String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  retailOrders RetailOrder[]
  wholesaleRfqs WholesaleRfq[]
  wholesaleDeals WholesaleDeal[]
  wonAuctions ProductAuction[] @relation("ProductAuctionWinner")
  auctionBids ProductAuctionBid[]
  preorderReservations ProductPreorderReservation[]

  @@index([userId])
  @@index([tenantId])
}

model Category {
  id          String    @id @default(cuid())
  parentId    String?
  slug        String    @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
}

model Product {
  id              String        @id @default(cuid())
  sellerProfileId String
  categoryId      String
  slug            String        @unique
  sku             String        @unique
  name            String
  description     String?
  seoTitle        String?
  metaDescription String?
  localizedContent Json?
  status          ProductStatus @default(draft)
  targetMarket    ProductTargetMarket @default(both)
  imageUrls       Json?
  availabilityStatus ProductAvailabilityStatus @default(in_stock)
  inventoryQuantity Int @default(0)
  leadTimeDays    Int?
  minimumOrderQuantity Int @default(1)
  compareAtAmountMinor Int?
  salePriceMinor  Int?
  saleStartsAt    DateTime?
  saleEndsAt      DateTime?
  isPreorderEnabled Boolean @default(false)
  preorderReleaseAt DateTime?
  preorderDepositAmountMinor Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Restrict)
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  prices        ProductPrice[]
  orderItems    RetailOrderItem[]
  auction       ProductAuction?
  preorderReservations ProductPreorderReservation[]

  @@index([sellerProfileId])
  @@index([categoryId])
  @@index([status])
  @@index([availabilityStatus])
}

model ProductPrice {
  id          String   @id @default(cuid())
  productId   String
  currency    String
  amountMinor Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductAuction {
  id                 String               @id @default(cuid())
  productId          String               @unique
  status             ProductAuctionStatus @default(active)
  currency           String
  startingBidMinor   Int
  reserveBidMinor    Int?
  currentBidMinor    Int?
  startsAt           DateTime
  endsAt             DateTime
  winnerBuyerProfileId String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  product            Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  winnerBuyerProfile BuyerProfile?        @relation("ProductAuctionWinner", fields: [winnerBuyerProfileId], references: [id], onDelete: SetNull)
  bids               ProductAuctionBid[]

  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@index([winnerBuyerProfileId])
}

model ProductAuctionBid {
  id             String         @id @default(cuid())
  auctionId      String
  buyerProfileId String
  amountMinor    Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  auction        ProductAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  buyerProfile   BuyerProfile   @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([buyerProfileId])
  @@index([amountMinor])
}

model ProductPreorderReservation {
  id             String               @id @default(cuid())
  productId      String
  buyerProfileId String
  quantity       Int
  unitAmountMinor Int
  totalAmountMinor Int
  status         ProductPreorderStatus @default(reserved)
  note           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  product        Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerProfile   BuyerProfile         @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerProfileId])
  @@index([status])
}

model RetailOrder {
  id               String      @id @default(cuid())
  buyerProfileId   String
  supplierProfileId String?
  status           RetailOrderStatus @default(created)
  paymentStatus    RetailPaymentStatus @default(pending)
  paymentTransactionId String? @unique
  shippingAddress  Json?
  currency         String
  totalAmountMinor Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  buyerProfile BuyerProfile     @relation(fields: [buyerProfileId], references: [id], onDelete: Restrict)
  supplierProfile SellerProfile? @relation(fields: [supplierProfileId], references: [id], onDelete: SetNull)
  items        RetailOrderItem[]
  paymentRecords PaymentRecord[]

  @@index([buyerProfileId])
  @@index([supplierProfileId])
  @@index([status])
  @@index([paymentStatus])
}

model RetailOrderItem {
  id               String   @id @default(cuid())
  retailOrderId    String
  productId        String
  quantity         Int
  unitAmountMinor  Int
  lineAmountMinor  Int
  currency         String
  productName      String
  productSlug      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  retailOrder RetailOrder @relation(fields: [retailOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([retailOrderId])
  @@index([productId])
}

model WholesaleRfq {
  id                String              @id @default(cuid())
  tenantId          String
  buyerProfileId    String?
  requestedByUserId String?
  title             String
  description       String?
  currency          String
  status            WholesaleRfqStatus  @default(open)
  selectedQuoteId   String?             @unique
  contractId        String?
  documentLinkage   Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buyerProfile      BuyerProfile?       @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)
  requestedByUser   User?               @relation("RfqRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  quotes            WholesaleQuote[]
  selectedQuote     WholesaleQuote?     @relation("SelectedQuoteForRfq", fields: [selectedQuoteId], references: [id], onDelete: SetNull)
  deal              WholesaleDeal?

  @@index([tenantId])
  @@index([buyerProfileId])
  @@index([requestedByUserId])
  @@index([status])
}

model WholesaleQuote {
  id             String               @id @default(cuid())
  rfqId          String
  sellerProfileId String
  amountMinor    Int
  currency       String
  message        String?
  status         WholesaleQuoteStatus @default(submitted)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  rfq            WholesaleRfq         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerProfile  SellerProfile        @relation(fields: [sellerProfileId], references: [id], onDelete: Restrict)
  acceptedForRfq WholesaleRfq?        @relation("SelectedQuoteForRfq")
  deal           WholesaleDeal?

  @@index([rfqId])
  @@index([sellerProfileId])
  @@index([status])
}

model WholesaleDeal {
  id             String              @id @default(cuid())
  rfqId          String              @unique
  acceptedQuoteId String             @unique
  tenantId       String
  buyerProfileId String?
  sellerProfileId String
  title          String
  status         WholesaleDealStatus @default(open)
  agreementSnapshot Json?
  contractId     String?
  documentLinkage Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  rfq            WholesaleRfq        @relation(fields: [rfqId], references: [id], onDelete: Restrict)
  acceptedQuote  WholesaleQuote      @relation(fields: [acceptedQuoteId], references: [id], onDelete: Restrict)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buyerProfile   BuyerProfile?       @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)
  sellerProfile  SellerProfile       @relation(fields: [sellerProfileId], references: [id], onDelete: Restrict)
  dealRoom       DealRoom?
  contract       Contract?
  documentLinks  DocumentLink[]
  paymentTransactions PaymentTransaction[]
  disputes       DisputeCase[]
  logisticsSelection DealLogisticsSelection?

  @@index([tenantId])
  @@index([buyerProfileId])
  @@index([sellerProfileId])
  @@index([status])
}

model DealRoom {
  id              String             @id @default(cuid())
  dealId          String             @unique
  status          DealRoomStatus     @default(active)
  latestMessage   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  deal            WholesaleDeal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Contract {
  id             String          @id @default(cuid())
  dealId         String          @unique
  contractType   ContractType
  status         ContractStatus  @default(draft)
  title          String
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  deal           WholesaleDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  versions       ContractVersion[]
  documentLinks  DocumentLink[]

  @@index([status])
  @@index([contractType])
}

model ContractRfq {
  id        String            @id @default(uuid())
  productId String
  qty       Int
  buyerUserId String?
  supplierUserId String?
  status    ContractRfqStatus @default(new)
  createdAt DateTime          @default(now())

  quotes    ContractRfqQuote[]
  deal      ContractRfqDeal?

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([buyerUserId])
  @@index([supplierUserId])
}

model ContractRfqQuote {
  id         String                 @id @default(uuid())
  rfqId      String                 @unique
  buyerUserId String?
  supplierUserId String?
  unitPrice  Int
  totalPrice Int
  currency   String
  note       String?
  status     ContractRfqQuoteStatus @default(submitted)
  createdAt  DateTime               @default(now())

  rfq        ContractRfq            @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  deal       ContractRfqDeal?

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([buyerUserId])
  @@index([supplierUserId])
}

model ContractRfqDeal {
  id             String                  @id @default(uuid())
  rfqId          String                  @unique
  quoteId        String                  @unique
  buyerUserId    String?
  supplierUserId String?
  buyerStatus    ContractDealPartyStatus @default(pending)
  supplierStatus ContractDealPartyStatus @default(pending)
  dealStatus     ContractDealStatus      @default(pending)
  agreementSnapshot Json?
  createdAt      DateTime                @default(now())

  rfq            ContractRfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  quote          ContractRfqQuote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  paymentRecords PaymentRecord[]

  @@index([createdAt(sort: Desc)])
  @@index([dealStatus])
  @@index([buyerUserId])
  @@index([supplierUserId])
}

model ContractVersion {
  id             String         @id @default(cuid())
  contractId     String
  versionNumber  Int
  label          String?
  storageBucket  String?
  storageKey     String?
  createdByUserId String?
  createdAt      DateTime       @default(now())

  contract       Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdByUser  User?          @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([contractId, versionNumber])
  @@index([createdByUserId])
}

model Document {
  id             String          @id @default(cuid())
  tenantId       String?
  uploadedByUserId String?
  documentType   DocumentType
  status         DocumentStatus  @default(uploaded)
  name           String
  contentType    String?
  storageBucket  String?
  storageKey     String?
  sizeBytes      Int?
  checksum       String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  uploadedByUser User?           @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  links          DocumentLink[]

  @@index([tenantId])
  @@index([uploadedByUserId])
  @@index([documentType])
  @@index([status])
}

model DocumentLink {
  id             String            @id @default(cuid())
  documentId     String
  dealId         String?
  contractId     String?
  linkType       DocumentLinkType
  createdAt      DateTime          @default(now())

  document       Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  deal           WholesaleDeal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contract       Contract?         @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([dealId])
  @@index([contractId])
  @@index([linkType])
}

model PaymentTransaction {
  id                 String                   @id
  dealId             String
  transactionType    PaymentTransactionType
  status             PaymentTransactionStatus @default(created)
  currency           String
  totalAmountMinor   Int
  heldAmountMinor    Int                      @default(0)
  releasedAmountMinor Int                     @default(0)
  refundedAmountMinor Int                     @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  deal               WholesaleDeal            @relation(fields: [dealId], references: [id], onDelete: Restrict)
  ledgerEntries      PaymentLedgerEntry[]
  disputes           DisputeCase[]

  @@index([dealId])
  @@index([status])
}

model PaymentLedgerEntry {
  id                   String            @id
  paymentTransactionId String
  entryType            PaymentLedgerEntryType
  amountMinor          Int
  resultingHeldMinor   Int
  resultingReleasedMinor Int
  resultingRefundedMinor Int
  note                 String?
  createdAt            DateTime          @default(now())

  paymentTransaction   PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)

  @@index([paymentTransactionId])
  @@index([entryType])
  @@index([createdAt])
}

model PaymentRecord {
  id               String               @id @default(cuid())
  scope            PaymentScope
  orderId          String?
  dealId           String?
  amountMinor      Int
  currency         String
  method           PaymentMethod
  provider         PaymentProvider
  status           PaymentRecordStatus   @default(pending)
  externalId       String?
  transactionId    String?              @unique
  bankReference    String?
  paymentReference String?              @unique
  instructions     Json?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  retailOrder      RetailOrder?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  deal             ContractRfqDeal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  attempts         PaymentAttempt[]

  @@index([orderId])
  @@index([dealId])
  @@index([scope])
  @@index([status])
  @@index([provider])
}

model PaymentAttempt {
  id               String               @id @default(cuid())
  paymentRecordId  String
  attemptType      PaymentAttemptType
  method           PaymentMethod
  provider         PaymentProvider
  status           PaymentRecordStatus
  amountMinor      Int
  currency         String
  externalId       String?
  transactionId    String?
  bankReference    String?
  paymentReference String?
  note             String?
  payload          Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  paymentRecord    PaymentRecord        @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)

  @@index([paymentRecordId])
  @@index([attemptType])
  @@index([status])
}

model DisputeCase {
  id                   String            @id @default(cuid())
  dealId               String?
  paymentTransactionId String?
  disputeType          DisputeType
  status               DisputeStatus     @default(open)
  reason               String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  deal                 WholesaleDeal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  paymentTransaction   PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([paymentTransactionId])
  @@index([status])
}

model LogisticsProvider {
  id             String                  @id @default(cuid())
  name           String
  status         LogisticsProviderStatus @default(draft)
  contactEmail   String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  capabilityProfile LogisticsCapabilityProfile?
  dealSelections     DealLogisticsSelection[]

  @@index([status])
}

model LogisticsCapabilityProfile {
  id                 String              @id @default(cuid())
  providerId         String              @unique
  transportTypes     Json?
  serviceTypes       Json?
  cargoCategories    Json?
  supportedRegions   Json?
  deliveryModes      Json?
  additionalServices Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  provider           LogisticsProvider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model DealLogisticsSelection {
  id                 String                        @id @default(cuid())
  dealId             String                        @unique
  logisticsProviderId String
  status             DealLogisticsSelectionStatus  @default(selected)
  notes              String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  deal               WholesaleDeal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  logisticsProvider  LogisticsProvider             @relation(fields: [logisticsProviderId], references: [id], onDelete: Restrict)

  @@index([logisticsProviderId])
  @@index([status])
}

model OperationalAssignment {
  id                    String                     @id @default(cuid())
  tenantId              String
  kind                  OperationalAssignmentKind
  subjectType           String
  subjectId             String
  partnerOrganizationId String?
  partnerUserId         String?
  reference             String?
  status                String
  notes                 String?
  metadata              Json?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partnerOrganization   Organization?              @relation(fields: [partnerOrganizationId], references: [id], onDelete: SetNull)
  partnerUser           User?                      @relation(fields: [partnerUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([kind])
  @@index([subjectType, subjectId])
  @@index([partnerOrganizationId])
  @@index([partnerUserId])
  @@index([status])
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles        UserRole[]
  rolePermissions  RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Membership {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  organizationId String?
  orgUnitId      String?
  membershipType MembershipType @default(member)
  status         MembershipStatus @default(active)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  orgUnit      OrgUnit?      @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, organizationId, orgUnitId])
  @@index([tenantId])
  @@index([userId])
  @@index([organizationId])
  @@index([orgUnitId])
}

model AuditEvent {
  id            String   @id @default(cuid())
  module        String
  eventType     String
  tenantId      String?
  correlationId String?
  actorId       String?
  subjectType   String?
  subjectId     String?
  payload       Json
  createdAt     DateTime @default(now())

  @@index([module])
  @@index([tenantId])
  @@index([subjectType, subjectId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actor      String
  actorId    String?
  metadata   Json
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([actor])
  @@index([createdAt])
  @@map("audit_log")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("notifications")
}

model AdminSetting {
  id            String   @id @default(cuid())
  key           String   @unique
  section       String
  value         Json
  updatedByUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([section])
  @@index([updatedAt])
}

model ConsentRecord {
  id              String   @id @default(cuid())
  userId          String?
  email           String?
  flow            String
  documentSlug    String
  documentTitle   String
  documentVersion String
  entityType      String?
  entityId        String?
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([flow])
  @@index([documentSlug, documentVersion])
  @@index([entityType, entityId])
  @@map("consent_records")
}

model Approval {
  id                String         @id @default(cuid())
  module            String
  approvalType      String
  status            ApprovalStatus @default(pending)
  tenantId          String?
  subjectType       String
  subjectId         String
  requestedByUserId String?
  decidedByUserId   String?
  requiredRoleCode  String?
  reason            String?
  payload           Json
  decisionComment   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  decidedAt         DateTime?

  requestedByUser   User?          @relation("ApprovalRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  decidedByUser     User?          @relation("ApprovalDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([module])
  @@index([tenantId])
  @@index([subjectType, subjectId])
  @@index([createdAt])
}

model OutboxMessage {
  id            String   @id @default(cuid())
  topic         String
  payload       Json
  status        String   @default("pending")
  availableAt   DateTime @default(now())
  processedAt   DateTime?
  correlationId String?
  createdAt     DateTime @default(now())
}

model InboxMessage {
  id             String   @id @default(cuid())
  provider       String
  externalId     String
  payload        Json
  status         String   @default("received")
  processedAt    DateTime?
  correlationId  String?
  createdAt      DateTime @default(now())

  @@unique([provider, externalId])
}

